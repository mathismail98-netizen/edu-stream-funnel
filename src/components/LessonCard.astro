---
interface Props {
  title: string;
  order: number;
  duration?: string;
  hasPdf: boolean;
  href: string;
}

const { title, order, duration, hasPdf, href } = Astro.props;
---

<a
  href={href}
  class="group flex items-start gap-4 p-4 rounded-lg border border-paper-200 bg-white hover:border-brick-500 hover:shadow-sm transition-all duration-150"
>
  <span class="shrink-0 mt-0.5 w-7 h-7 flex items-center justify-center rounded-full bg-paper-100 text-ink-600 text-xs font-medium font-sans group-hover:bg-brick-500 group-hover:text-white transition-colors duration-150">
    {order}
  </span>
  <div class="min-w-0 flex-1">
    <p class="font-serif text-base font-semibold text-ink-900 group-hover:text-brick-500 transition-colors duration-150 leading-snug">
      {title}
    </p>
    <div class="mt-1 flex items-center gap-3 text-xs text-ink-400">
      {duration && <span>{duration}</span>}
      {duration && hasPdf && <span aria-hidden="true">·</span>}
      {hasPdf && (
        <span class="flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          PDF included
        </span>
      )}
    </div>
  </div>
  <svg
    class="shrink-0 w-4 h-4 text-ink-400 group-hover:text-brick-500 mt-1 transition-colors duration-150"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
</a>
