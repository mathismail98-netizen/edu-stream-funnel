---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import LevelSubNav from '../../components/LevelSubNav.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', l => !l.data.draft);
  return lessons.map(lesson => {
    const levelSlug = lesson.data.level;
    const prefix = levelSlug + '-';
    const lessonSlug = lesson.slug.startsWith(prefix)
      ? lesson.slug.slice(prefix.length)
      : lesson.slug;
    return {
      params: { level: levelSlug, lesson: lessonSlug },
      props: { lesson },
    };
  });
}

const { lesson } = Astro.props;
const { title, level, type, pdfCategory, videoId, pdf, duration, notes } = lesson.data;

const activeTab =
  type === 'video'
    ? 'videos'
    : pdfCategory === 'series'
      ? 'series-pdf'
      : pdfCategory === 'devoirs'
        ? 'devoirs-pdf'
        : 'cours-pdf';

const pdfLabel =
  pdfCategory === 'series'
    ? 'Séries PDF'
    : pdfCategory === 'devoirs'
      ? 'Devoirs PDF'
      : 'Cours PDF';

const contentLabel = type === 'video' ? 'Cours Vidéos' : pdfLabel;

// Prev/next within same type
const siblings = await getCollection(
  'lessons',
  l => !l.data.draft && l.data.level === level && l.data.type === type
);
const sorted = siblings.sort((a, b) => a.data.order - b.data.order);
const idx = sorted.findIndex(l => l.slug === lesson.slug);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

const levelData = (await getCollection('levels')).find(l => l.id === level);

function slug(l: typeof sorted[number]) {
  const prefix = l.data.level + '-';
  return l.slug.startsWith(prefix) ? l.slug.slice(prefix.length) : l.slug;
}
---

<BaseLayout title={title} currentLevel={level}>
  <section class="border-b border-slate-200/80 bg-white/70">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <nav class="flex flex-wrap items-center gap-2 text-xs text-slate-400" aria-label="Fil d'Ariane">
        <a href="/" class="transition hover:text-slate-900">Accueil</a>
        <span>/</span>
        <a href={`/${level}/`} class="transition hover:text-slate-900">{levelData?.data.title ?? level}</a>
        <span>/</span>
        <span class="text-slate-600">{contentLabel}</span>
      </nav>

      <div class="mt-6 grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-500">Leçon</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">{title}</h1>
          {duration && <p class="mt-4 text-sm font-medium text-slate-500">Durée estimée: {duration}</p>}
        </div>

        <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm lg:justify-self-end">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Navigation</p>
          <p class="mt-2 text-sm leading-7 text-slate-600">Utilisez les cartes ci-dessous pour avancer dans la progression du niveau.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sub-nav -->
  <LevelSubNav levelSlug={level} active={activeTab} />

  <!-- Content -->
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    {type === 'video' && videoId ? (
      <div class="space-y-6 rounded-[2rem] border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
        <YouTubeEmbed videoId={videoId} title={title} />
        {pdf && (
          <a
            href={pdf}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-slate-800"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Télécharger la fiche PDF
          </a>
        )}
        {notes && (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm leading-relaxed text-slate-600">
            {notes}
          </div>
        )}
      </div>
    ) : type === 'pdf' && pdf ? (
      <div class="space-y-6 rounded-[2rem] border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
        <div class="flex flex-col items-center gap-4 rounded-[1.75rem] border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
          <svg class="h-12 w-12 text-rose-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5z"/>
          </svg>
          <div>
            <p class="mb-1 text-lg font-semibold text-slate-950">{title}</p>
            {notes && <p class="max-w-sm text-sm text-slate-500">{notes}</p>}
          </div>
          <a
            href={pdf}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-slate-800"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Télécharger le PDF
          </a>
        </div>
      </div>
    ) : (
      <p class="text-gray-400 text-sm">Contenu non disponible.</p>
    )}

    <!-- Prev / Next -->
    <nav class="mt-12 flex items-center justify-between gap-4 border-t border-slate-200 pt-6" aria-label="Navigation entre leçons">
      {prev ? (
        <a
          href={`/${level}/${slug(prev)}/`}
          class="group flex max-w-[45%] items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-3 text-sm text-slate-500 transition hover:-translate-y-0.5 hover:border-slate-300 hover:text-slate-950"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="truncate">{prev.data.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a
          href={`/${level}/${slug(next)}/`}
          class="group flex max-w-[45%] items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-3 text-right text-sm text-slate-500 transition hover:-translate-y-0.5 hover:border-slate-300 hover:text-slate-950"
        >
          <span class="truncate">{next.data.title}</span>
          <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ) : <span />}
    </nav>
  </div>
</BaseLayout>
