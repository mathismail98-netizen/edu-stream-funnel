---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LevelSubNav from '../../components/LevelSubNav.astro';

export async function getStaticPaths() {
  const levels = await getCollection('levels');
  return levels.map(level => ({
    params: { level: level.id },
    props: { level },
  }));
}

const { level } = Astro.props;

const allLessons = await getCollection('lessons', l => !l.data.draft && l.data.level === level.id && l.data.type === 'video');
const videos = allLessons.sort((a, b) => a.data.order - b.data.order);

const pdfCount = (await getCollection('lessons', l => !l.data.draft && l.data.level === level.id && l.data.type === 'pdf')).length;

function lessonSlug(slug: string, levelId: string) {
  const prefix = levelId + '-';
  return slug.startsWith(prefix) ? slug.slice(prefix.length) : slug;
}

function ytThumb(videoId: string) {
  return `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;
}
---

<BaseLayout title={`Cours Vidéos — ${level.data.title}`} currentLevel={level.id}>
  <section class="border-b border-cyan-100/80 bg-white/70">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-500">Niveau</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">{level.data.title}</h1>
          <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600">{level.data.description}</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:justify-self-end">
          <div class="glass-card rounded-[1.5rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Cours vidéos</p>
            <p class="mt-2 text-3xl font-semibold tracking-tight text-cyan-700">{videos.length}</p>
          </div>
          <div class="glass-card rounded-[1.5rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">PDF associés</p>
            <p class="mt-2 text-3xl font-semibold tracking-tight text-emerald-700">{pdfCount}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sub-nav -->
  <LevelSubNav levelSlug={level.id} active="videos" />

  <!-- Videos grid -->
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    {videos.length === 0 ? (
      <div class="glass-card rounded-[1.75rem] border-dashed border-cyan-200 px-6 py-16 text-center text-sm text-slate-500">
        Aucune vidéo disponible pour le moment. Revenez bientôt.
      </div>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
        {videos.map(lesson => (
          <a
            href={`/${level.id}/${lessonSlug(lesson.slug, level.id)}/`}
            class="group flex flex-col overflow-hidden rounded-[1.6rem] border border-cyan-100 bg-white/88 shadow-sm backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-cyan-300 hover:shadow-[0_24px_70px_rgba(15,23,42,0.12)]"
          >
            <!-- Thumbnail -->
            <div class="relative aspect-video overflow-hidden bg-slate-100">
              {lesson.data.videoId && (
                <img
                  src={ytThumb(lesson.data.videoId)}
                  alt={lesson.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              )}
              <!-- Play button overlay -->
              <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-t from-cyan-900/30 via-transparent to-emerald-800/10">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/95 text-cyan-700 shadow-lg shadow-cyan-700/20 transition group-hover:scale-105">
                  <svg class="ml-0.5 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              {lesson.data.duration && (
                <span class="absolute bottom-3 right-3 rounded-full bg-gradient-to-r from-cyan-600/90 to-emerald-600/90 px-2.5 py-1 text-xs font-medium text-white backdrop-blur">
                  {lesson.data.duration}
                </span>
              )}
            </div>
            <!-- Info -->
            <div class="flex-1 p-5">
              <p class="line-clamp-2 text-sm font-semibold leading-snug text-slate-950 group-hover:text-slate-700">
                {lesson.data.title}
              </p>
              <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
                <span>Leçon {lesson.data.order}</span>
                <span class="inline-flex items-center gap-1 rounded-full bg-cyan-50 px-2.5 py-1 font-medium text-cyan-700">
                  Voir le cours
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
