---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LevelSubNav from '../../../components/LevelSubNav.astro';

export async function getStaticPaths() {
  const levels = await getCollection('levels');
  return levels.map(level => ({
    params: { level: level.id },
    props: { level },
  }));
}

const { level } = Astro.props;

const allLessons = await getCollection('lessons', l => {
  return !l.data.draft && l.data.level === level.id && l.data.type === 'pdf' && l.data.pdfCategory === 'series';
});
const pdfs = allLessons.sort((a, b) => a.data.order - b.data.order);

function lessonSlug(slug: string, levelId: string) {
  const prefix = levelId + '-';
  return slug.startsWith(prefix) ? slug.slice(prefix.length) : slug;
}
---

<BaseLayout title={`Séries PDF — ${level.data.title}`} currentLevel={level.id}>
  <section class="border-b border-slate-200/80 bg-white/70">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-500">Niveau</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">{level.data.title}</h1>
          <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600">{level.data.description}</p>
        </div>

        <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm lg:justify-self-end">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Séries PDF</p>
          <p class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">{pdfs.length}</p>
        </div>
      </div>
    </div>
  </section>

  <LevelSubNav levelSlug={level.id} active="series-pdf" />

  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    {pdfs.length === 0 ? (
      <div class="rounded-[1.75rem] border border-dashed border-slate-300 bg-white/80 px-6 py-16 text-center text-sm text-slate-500 shadow-sm">
        Aucune serie PDF disponible pour le moment. Revenez bientot.
      </div>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {pdfs.map(lesson => (
          <a
            href={lesson.data.pdf ?? `/${level.id}/${lessonSlug(lesson.slug, level.id)}/`}
            target={lesson.data.pdf ? '_blank' : undefined}
            rel={lesson.data.pdf ? 'noopener noreferrer' : undefined}
            class="group flex items-start gap-4 rounded-[1.6rem] border border-slate-200 bg-white p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-slate-300 hover:shadow-[0_24px_70px_rgba(15,23,42,0.08)]"
          >
            <div class="shrink-0 flex h-12 w-10 flex-col items-center justify-center rounded-xl border border-rose-100 bg-rose-50">
              <svg class="h-6 w-5 text-rose-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8.5 17.5h-1v-5h1.8c1.1 0 1.7.55 1.7 1.5s-.6 1.5-1.7 1.5H8.5v2zm0-2.8h.8c.5 0 .7-.2.7-.7s-.2-.7-.7-.7H8.5v1.4zm4.2 2.8h-1.1v-5h1.1c1.4 0 2.2.9 2.2 2.5s-.8 2.5-2.2 2.5zm0-4.2h-.1v3.4h.1c.75 0 1.1-.55 1.1-1.7s-.35-1.7-1.1-1.7zm4.3 1.1v.8h-1.4v1.5h1.6v.8H15v-5h2.6v.8H16v1.1h1.5z"/>
              </svg>
              <span class="text-xs font-bold text-rose-500">PDF</span>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold leading-snug text-slate-950 group-hover:text-slate-700">
                {lesson.data.title}
              </p>
              {lesson.data.notes && (
                <p class="mt-1 line-clamp-2 text-xs text-slate-500">{lesson.data.notes}</p>
              )}
              <span class="mt-3 inline-flex items-center gap-1 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 transition group-hover:bg-slate-950 group-hover:text-white">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Telecharger
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
