---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const levels = await getCollection('levels');
const allLessons = await getCollection('lessons', l => !l.data.draft);

const sortedLevels = levels.sort((a, b) => a.data.order - b.data.order);

const totalVideos = allLessons.filter(lesson => lesson.data.type === 'video').length;
const totalPdfs = allLessons.filter(lesson => lesson.data.type === 'pdf').length;

const spotlightLevels = sortedLevels.slice(0, 3);

function countByType(levelSlug: string, type: 'video' | 'pdf') {
  return allLessons.filter(l => l.data.level === levelSlug && l.data.type === type).length;
}
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 pb-8 pt-8 sm:px-6 lg:px-8 lg:pb-14 lg:pt-14">
      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-cyan-200 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-slate-600 shadow-sm backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-cyan-500"></span>
            Cours gratuits, organisés par niveau
          </div>
          <h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-7xl">
            Apprendre plus vite avec des <span class="text-brand-gradient">vidéos</span>, des PDF et des devoirs bien structurés.
          </h1>
          <p class="mt-6 max-w-xl text-base leading-8 text-slate-600 sm:text-lg">
            {site.description} La navigation est pensée pour aller droit au contenu, avec une hiérarchie claire et une expérience mobile fluide.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={`/${spotlightLevels[0]?.id ?? '1apic'}/`} class="btn-brand">
              Commencer par le premier niveau
            </a>
            <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="btn-soft">
              Voir la chaîne YouTube
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="glass-card p-5">
              <p class="text-3xl font-semibold tracking-tight text-cyan-700">{sortedLevels.length}</p>
              <p class="mt-1 text-sm text-slate-500">Niveaux disponibles</p>
            </div>
            <div class="glass-card p-5">
              <p class="text-3xl font-semibold tracking-tight text-emerald-700">{totalVideos}</p>
              <p class="mt-1 text-sm text-slate-500">Cours vidéo</p>
            </div>
            <div class="glass-card p-5">
              <p class="text-3xl font-semibold tracking-tight text-amber-600">{totalPdfs}</p>
              <p class="mt-1 text-sm text-slate-500">PDF disponibles</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 -z-10 translate-y-6 rounded-[2rem] bg-gradient-to-br from-cyan-300/20 via-emerald-200/20 to-amber-200/20 blur-2xl"></div>
          <div class="glass-card rounded-[2rem] p-5 sm:p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Navigation rapide</p>
                <p class="mt-2 text-lg font-semibold text-slate-950">Accès direct par niveau</p>
              </div>
              <div class="rounded-full bg-gradient-to-r from-cyan-500 to-emerald-500 px-3 py-1 text-xs font-semibold text-white">Live</div>
            </div>
            <div class="mt-6 grid gap-3">
              {spotlightLevels.map(level => {
                const videos = countByType(level.id, 'video');
                const pdfs = countByType(level.id, 'pdf');
                return (
                  <a href={`/${level.id}/`} class="group flex items-center justify-between rounded-2xl border border-cyan-100 bg-white/85 px-4 py-4 transition hover:-translate-y-0.5 hover:border-cyan-300 hover:bg-cyan-50/40">
                    <div>
                      <p class="text-sm font-semibold text-slate-950 group-hover:text-slate-700">{level.data.title}</p>
                      <p class="mt-1 text-xs text-slate-500">{videos} vidéos · {pdfs} PDF</p>
                    </div>
                    <svg class="h-5 w-5 text-slate-400 transition-transform group-hover:translate-x-1 group-hover:text-slate-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 lg:py-10">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="glass-card p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Expérience</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">Une interface sobre, rapide et centrée sur l’essentiel.</p>
      </div>
      <div class="glass-card p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Contenu</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">Les ressources sont regroupées pour réduire le temps de recherche.</p>
      </div>
      <div class="glass-card p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Mobile</p>
        <p class="mt-3 text-lg font-semibold text-slate-950">Navigation claire et CTA lisibles sur petit écran.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-14">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">Choisissez votre niveau</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950 sm:text-3xl">Tout le parcours est organisé en cartes claires et actionnables.</h2>
      </div>
      <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="hidden btn-soft px-4 py-2 md:inline-flex">
        Accéder aux vidéos
      </a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sortedLevels.map(level => {
        const videos = countByType(level.id, 'video');
        const pdfs = countByType(level.id, 'pdf');
        return (
          <a
            href={`/${level.id}/`}
            class="group relative overflow-hidden rounded-[1.75rem] border border-cyan-100 bg-white/88 p-6 shadow-sm backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-cyan-300 hover:shadow-[0_20px_60px_rgba(15,23,42,0.10)]"
          >
            <div class="brand-divider absolute inset-x-0 top-0 h-1 opacity-95"></div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-slate-500">Niveau</p>
                <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-950 group-hover:text-slate-700">{level.data.title}</h3>
              </div>
              <div class="rounded-full bg-gradient-to-r from-cyan-500 to-emerald-500 px-3 py-1.5 text-xs font-semibold text-white">{level.data.order.toString().padStart(2, '0')}</div>
            </div>
            <p class="mt-4 text-sm leading-7 text-slate-600">{level.data.description}</p>
            <div class="mt-6 grid grid-cols-2 gap-3 text-sm text-slate-500">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <span class="block text-xs uppercase tracking-[0.24em] text-slate-400">Vidéos</span>
                <span class="mt-1 block font-semibold text-slate-950">{videos}</span>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <span class="block text-xs uppercase tracking-[0.24em] text-slate-400">PDF</span>
                <span class="mt-1 block font-semibold text-slate-950">{pdfs}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
