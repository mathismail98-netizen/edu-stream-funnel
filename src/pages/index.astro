---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { navLevels } from '../config/site';

const levels = await getCollection('levels');
const allLessons = await getCollection('lessons', l => !l.data.draft);

const sortedLevels = levels.sort((a, b) => a.data.order - b.data.order);

function countByType(levelSlug: string, type: 'video' | 'pdf') {
  return allLessons.filter(l => l.data.level === levelSlug && l.data.type === type).length;
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-16 text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-4">Cours en ligne gratuits</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4 leading-tight">
        Prof<span class="font-normal">OUDAHA ISMAIL</span>
      </h1>
      <p class="text-lg text-gray-600 max-w-xl mx-auto leading-relaxed">
        Cours vidéos et fiches PDF pour réussir vos études. Choisissez votre niveau ci-dessous.
      </p>
    </div>
  </section>

  <!-- Level grid -->
  <section class="max-w-7xl mx-auto px-6 py-14">
    <h2 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-8">Choisissez votre niveau</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sortedLevels.map(level => {
        const videos = countByType(level.id, 'video');
        const pdfs = countByType(level.id, 'pdf');
        return (
          <a
            href={`/${level.id}/`}
            class="group block p-6 rounded-xl border border-gray-200 bg-white hover:border-gray-400 hover:shadow-md transition-all duration-200"
          >
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-gray-700 mb-2">
              {level.data.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-5">
              {level.data.description}
            </p>
            <div class="flex items-center gap-4 text-xs text-gray-400">
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {videos} vidéo{videos !== 1 ? 's' : ''}
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                {pdfs} fiche{pdfs !== 1 ? 's' : ''} PDF
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
