---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  currentLevel?: string;
}

const { title, description = site.description, currentLevel } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.name;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const headerLevels = (await getCollection('levels'))
  .sort((a, b) => a.data.order - b.data.order)
  .map(level => ({ slug: level.id, label: level.data.title }));
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-44 left-1/2 h-[30rem] w-[50rem] -translate-x-1/2 rounded-full bg-cyan-200/45 blur-3xl"></div>
      <div class="absolute top-64 right-[-8rem] h-96 w-96 rounded-full bg-emerald-200/45 blur-3xl"></div>
      <div class="absolute bottom-0 left-[-7rem] h-80 w-80 rounded-full bg-amber-100/45 blur-3xl"></div>
    </div>

    <!-- ── HEADER ── -->
    <header class="sticky top-0 z-50 border-b border-white/70 bg-white/80 backdrop-blur-xl shadow-[0_1px_0_rgba(15,23,42,0.05)]">
      <div class="border-b border-cyan-200/30 bg-gradient-to-r from-cyan-700 via-sky-700 to-emerald-700 text-white">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-2 text-[11px] sm:px-6 lg:px-8">
          <p class="truncate uppercase tracking-[0.32em] text-white/80">{site.description}</p>
          <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="inline-flex shrink-0 items-center gap-2 rounded-full border border-white/30 bg-white/15 px-3 py-1.5 font-medium text-white transition hover:bg-white/25">
            <span class="h-1.5 w-1.5 rounded-full bg-amber-300"></span>
            Suivre la chaîne
          </a>
        </div>
      </div>

      <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-4 sm:px-6 lg:px-8 lg:gap-8 lg:py-5">
        <a href="/" class="group inline-flex shrink-0 items-center gap-3 text-gray-950 transition-transform duration-200 hover:-translate-y-0.5">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-500 to-emerald-500 text-sm font-bold text-white shadow-lg shadow-cyan-600/30">P</span>
          <span class="leading-none">
            <span class="block text-[10px] font-semibold uppercase tracking-[0.34em] text-gray-500">{site.nameBold}</span>
            <span class="block text-lg font-semibold tracking-tight sm:text-xl">{site.nameLight}</span>
          </span>
        </a>

        <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="Navigation principale">
          <a
            href="/"
            class={`rounded-full px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.28em] transition ${
              isHome
                ? 'bg-gradient-to-r from-cyan-500 to-emerald-500 text-white shadow-sm'
                : 'text-slate-600 hover:bg-cyan-50 hover:text-slate-950'
            }`}
          >
            Accueil
          </a>
          {headerLevels.map(level => {
            const isActive = currentLevel === level.slug;
            return (
              <a
                href={`/${level.slug}/`}
                class={`rounded-full px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.28em] transition ${
                  isActive
                    ? 'bg-gradient-to-r from-cyan-500 to-emerald-500 text-white shadow-sm'
                    : 'text-slate-600 hover:bg-cyan-50 hover:text-slate-950'
                }`}
              >
                {level.label}
              </a>
            );
          })}
        </nav>

        <div class="hidden lg:block">
          <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="btn-brand px-4 py-2 text-sm">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14m-6 4h4a2 2 0 002-2V8a2 2 0 00-2-2H9a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            Regarder
          </a>
        </div>

        <div class="ml-auto lg:hidden">
          <button id="mobile-menu-btn" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-cyan-200 bg-white text-slate-700 shadow-sm transition hover:border-cyan-300 hover:text-slate-950" aria-label="Menu">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <div id="mobile-nav" class="hidden border-t border-cyan-100 bg-white/95 backdrop-blur-xl lg:hidden">
        <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
          <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="mb-4 flex items-center justify-between rounded-2xl border border-cyan-200 bg-gradient-to-r from-cyan-50 to-emerald-50 px-4 py-3 text-sm font-medium text-slate-700">
            <span>Accéder à la chaîne YouTube</span>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h4m0 0v4m0-4L10 14m-4 3h8a2 2 0 002-2V7" />
            </svg>
          </a>
          <div class="grid gap-2">
            <a href="/" class={`rounded-2xl border px-4 py-3 text-sm font-semibold transition ${isHome ? 'border-cyan-500 bg-gradient-to-r from-cyan-500 to-emerald-500 text-white' : 'border-slate-200 bg-white text-slate-700'}`}>Accueil</a>
            {headerLevels.map(level => (
              <a
                href={`/${level.slug}/`}
                class={`rounded-2xl border px-4 py-3 text-sm font-semibold transition ${currentLevel === level.slug ? 'border-cyan-500 bg-gradient-to-r from-cyan-500 to-emerald-500 text-white' : 'border-slate-200 bg-white text-slate-700'}`}
              >
                {level.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </header>

    <!-- ── MAIN ── -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- ── FOOTER ── -->
    <footer class="mt-24 border-t border-cyan-200/30 bg-gradient-to-br from-slate-950 via-slate-900 to-cyan-950 text-white">
      <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr_1fr]">
          <div class="max-w-lg">
            <a href="/" class="inline-flex items-center gap-3 text-white transition-opacity hover:opacity-80">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-400 to-emerald-400 text-sm font-bold text-slate-950">P</span>
              <span>
                <span class="block text-[10px] font-semibold uppercase tracking-[0.34em] text-white/55">{site.nameBold}</span>
                <span class="block text-lg font-semibold tracking-tight">{site.nameLight}</span>
              </span>
            </a>
            <p class="mt-5 max-w-md text-sm leading-7 text-white/65">{site.description} Une plateforme claire, rapide et pensée pour mettre les ressources essentielles à portée de main.</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href={site.channelUrl} target="_blank" rel="noopener noreferrer" class="btn-brand px-4 py-2.5 text-sm">
                Regarder les vidéos
              </a>
              <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2 rounded-full border border-white/15 px-4 py-2.5 text-sm font-semibold text-white transition hover:border-white/30 hover:bg-white/5">
                Nous contacter
              </a>
            </div>
          </div>

          <div>
            <h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-white/45">Navigation</h2>
            <nav class="mt-5 grid gap-3" aria-label="Liens footer">
              {site.footerLinks.map(link => (
                <a href={link.href} class="text-sm text-white/70 transition hover:text-white">{link.label}</a>
              ))}
            </nav>
          </div>

          <div>
            <h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-white/45">Rester en contact</h2>
            <div class="mt-5 grid gap-3 text-sm text-white/70">
              <a href={`mailto:${site.email}`} class="transition hover:text-white">{site.email}</a>
              <span>{site.phone}</span>
            </div>
            <div class="mt-6 flex items-center gap-4">
              <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white/70 transition hover:border-white/25 hover:bg-white/5 hover:text-white">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white/70 transition hover:border-white/25 hover:bg-white/5 hover:text-white">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
              <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 text-white/70 transition hover:border-white/25 hover:bg-white/5 hover:text-white">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136C4.495 20.455 12 20.455 12 20.455s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <div class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-white/40 sm:flex-row sm:items-center sm:justify-between">
          <span>Copyright 2024-2026, tous droits réservés</span>
          <span class="flex items-center gap-4">
            <span>{site.email}</span>
            <span>{site.phone}</span>
          </span>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const nav = document.getElementById('mobile-nav');
      btn?.addEventListener('click', () => nav?.classList.toggle('hidden'));
    </script>
  </body>
</html>
